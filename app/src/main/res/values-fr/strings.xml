    <string name="title_how_to_use">Comment utiliser</string>
    <string name="desc_how_to_use">1. Connectez le téléphone et Tesla au même WiFi\n2. Appuyez sur \"Démarrer la mise en miroir\" ci-dessus\n3. Ouvrez l\'URL dans le navigateur de Tesla\n4. L\'écran de votre téléphone apparaîtra sur Tesla</string>


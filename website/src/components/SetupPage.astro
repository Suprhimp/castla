---
import { type Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = useTranslations(lang);
---

<section>
  <div class="container" style="max-width:760px;">
    <!-- Header with logo -->
    <div class="setup-header" style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
      <div style="width:48px; height:48px; border-radius:14px; background:#0A0A0A; border:1px solid rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
          <defs>
            <linearGradient id="logo-g" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#FF5252"/>
              <stop offset="100%" stop-color="#2979FF"/>
            </linearGradient>
          </defs>
          <rect width="32" height="32" rx="8" fill="#0A0A0A"/>
          <text x="16" y="23" font-family="system-ui" font-size="20" font-weight="bold" fill="url(#logo-g)" text-anchor="middle">C</text>
        </svg>
      </div>
      <h1 style="font-size:clamp(1.5rem, 5vw, 2.2rem); font-weight:800; line-height:1.2; color:var(--text);">
        {tr('setup.title')}
      </h1>
    </div>
    <p class="subtitle" style="font-size:clamp(0.9rem, 3vw, 1.05rem); line-height:1.8;">{tr('setup.desc')}</p>

    <!-- Step 1 -->
    <div class="glass" style="margin-bottom:24px;">
      <div class="steps">
        <div class="step">
          <h3>{tr('setup.1.title')}</h3>
          <p>{tr('setup.1.desc')}</p>
          <p style="margin-top:12px;">
            <a href="https://github.com/RikkaApps/Shizuku/releases" class="btn btn-primary" style="font-size:0.9rem; padding:10px 20px;">
              {tr('setup.1.btn')}
            </a>
          </p>
        </div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="glass" style="margin-bottom:24px;">
      <div class="steps" style="counter-reset: step 1;">
        <div class="step">
          <h3>{tr('setup.2.title')}</h3>
          <p>{tr('setup.2.desc')}</p>
          <ol style="margin-top:12px; padding-left:20px; color:var(--text-dim); line-height:2;">
            {tr('setup.2.steps').split('|').map((s) => <li set:html={s} />)}
          </ol>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="glass" style="margin-bottom:24px;">
      <div class="steps" style="counter-reset: step 2;">
        <div class="step">
          <h3>{tr('setup.3.title')}</h3>
          <p>{tr('setup.3.desc')}</p>
          <ol style="margin-top:12px; padding-left:20px; color:var(--text-dim); line-height:2;">
            {tr('setup.3.steps').split('|').map((s) => <li set:html={s} />)}
          </ol>
        </div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="glass" style="margin-bottom:24px;">
      <div class="steps" style="counter-reset: step 3;">
        <div class="step">
          <h3>{tr('setup.4.title')}</h3>
          <ol style="margin-top:8px; padding-left:20px; color:var(--text-dim); line-height:2;">
            {tr('setup.4.steps').split('|').map((s) => <li set:html={s} />)}
          </ol>
        </div>
      </div>
    </div>

    <!-- Step 5 -->
    <div class="glass" style="margin-bottom:24px;">
      <div class="steps" style="counter-reset: step 4;">
        <div class="step">
          <h3>{tr('setup.5.title')}</h3>
          <p>{tr('setup.5.desc')}</p>
        </div>
      </div>
    </div>

    <!-- Troubleshooting -->
    <div class="glass">
      <h3 style="margin-bottom:16px;">{tr('setup.trouble.title')}</h3>
      <div style="display:flex; flex-direction:column; gap:16px;">
        <div>
          <h4 style="color:var(--coral); font-size:0.95rem;">{tr('setup.trouble.1.q')}</h4>
          <p style="color:var(--text-dim); font-size:0.9rem;">{tr('setup.trouble.1.a')}</p>
        </div>
        <div>
          <h4 style="color:var(--coral); font-size:0.95rem;">{tr('setup.trouble.2.q')}</h4>
          <p style="color:var(--text-dim); font-size:0.9rem;">{tr('setup.trouble.2.a')}</p>
        </div>
      </div>
    </div>
  </div>
</section>
